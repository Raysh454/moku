{
  "name": "MOKU-Frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:api": "swagger2openapi --patch ../docs/swagger/swagger.json --outfile src/api/openapi3.json && openapi-typescript src/api/openapi3.json -o src/api/generated.ts"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.11",
    "@pierre/trees": "^1.0.0-beta.4",
    "@tailwindcss/vite": "^4.3.0",
    "lucide-react": "^1.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "swagger2openapi": "^7.0.8",
    "typescript": "~6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.8"
  }
}
