# openapi-typescript (dev-only swagger codegen) declares a peer of
# typescript@^5.x, but this project is pinned to typescript@~6.0.3. The CLI
# runs fine against TS 6 — it only consumes the OpenAPI document, not the
# project's TS version — so tolerate the soft peer mismatch here. Keeping this
# in .npmrc makes `npm ci` (CI) and local installs reproducible without a flag.
legacy-peer-deps=true
